VITE_API_BASE_URL=/api
VITE_API_TIMEOUT=15000
# Configurações do Proxy Vite (desenvolvimento)
# Endereço da API para o proxy do Vite
VITE_PROXY_TARGET=https://localhost:8443
# Segurança do proxy. Use false para não validar certificado SSL/TLS da API, true para validar
# Use true em produção, false em desenvolvimento (certificado auto-assinado)
VITE_PROXY_SECURE=false
# Configurações de Ambiente
VITE_APP_NAME="Comandas do Zé"
VITE_APP_VERSION="1.0.0"
# Flags de Debug
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=info